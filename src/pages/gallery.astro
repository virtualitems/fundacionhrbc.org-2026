---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/jpeg" href="/favicon.jpg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Galería fotográfica de Fundación HRBC — memoria visual de nuestros programas, talleres y redes de trabajo comunitario." />
		<title>Galería de Fotos — Fundación HRBC</title>
	</head>
	<body class="bg-background text-foreground antialiased">

		<!-- Header -->
		<header class="fixed left-0 right-0 top-0 z-50 backdrop-blur-xl">
			<nav class="mx-auto flex w-full max-w-7xl items-center justify-between border-b border-border/20 bg-background/80 px-6 py-4 2xl:px-8">
				<a href="/" class="group flex items-center gap-3">
					<img src="/icon.jpg" alt="HRBC Logo" class="h-12 w-auto rounded-lg transition-transform duration-300 group-hover:scale-105" />
					<span class="font-bold uppercase tracking-[0.15em]">Fundación HRBC</span>
				</a>
				<div class="hidden items-center gap-2 2xl:flex">
					<a class="px-4 py-2 text-sm font-medium transition hover:text-secondary" href="/#nosotros">Nosotros</a>
					<a class="px-4 py-2 text-sm font-medium transition hover:text-secondary" href="/#impacto">Impacto</a>
					<a class="px-4 py-2 text-sm font-medium transition hover:text-secondary" href="/#programas">Programas</a>
					<a class="px-4 py-2 text-sm font-semibold text-secondary" href="/gallery">Galería</a>
					<a class="ml-3 rounded-xl bg-secondary px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-accent" href="/#contacto">Contactar</a>
				</div>
			</nav>
		</header>

		<!-- Hero -->
		<section class="relative overflow-hidden pt-20">
			<div class="pointer-events-none absolute inset-0 -z-10 bg-linear-to-br from-secondary/10 via-background to-accent/5"></div>
			<div class="mx-auto w-full max-w-7xl px-6 py-14 2xl:px-8 2xl:py-24">
				<div class="max-w-3xl space-y-4">
					<div class="inline-block rounded-full border border-secondary/30 bg-secondary/5 px-4 py-2 text-sm font-semibold text-secondary">
						— Memoria visual
					</div>
					<h1 class="font-['Space_Grotesk',sans-serif] text-4xl font-black leading-tight tracking-tight 2xl:text-7xl">
						Galería de <span class="text-secondary">Fotos</span>
					</h1>
					<p class="text-base leading-relaxed text-foreground/70 2xl:text-xl">
						Registro fotográfico de nuestros programas, talleres, redes y actividades comunitarias a lo largo de los años.
					</p>
				</div>
			</div>
		</section>

		<!-- Gallery Sections -->
		<main class="mx-auto w-full max-w-7xl px-6 pb-24 2xl:px-8">
			{sections.map((section, si) => (
				<section class="mb-20 2xl:mb-32">
					<!-- Section header -->
					<div class={`mb-10 border-l-4 pl-6 2xl:mb-16 ${si === 0 ? "border-secondary" : si === 1 ? "border-accent" : "border-primary"}`}>
						<h2 class="font-['Space_Grotesk',sans-serif] text-2xl font-black leading-tight tracking-tight 2xl:text-5xl">
							{section.title}
						</h2>
						{section.subtitle && (
							<p class="mt-1 text-sm font-semibold text-secondary 2xl:text-base">{section.subtitle}</p>
						)}
						{section.note && (
							<p class="mt-3 max-w-2xl text-sm leading-relaxed text-foreground/60 2xl:text-base">{section.note}</p>
						)}
					</div>

					{section.subsections.map((sub) => (
						<div class="mb-14 2xl:mb-20">
							{sub.title && (
								<div class="mb-6 2xl:mb-8">
									<h3 class="text-lg font-bold text-foreground 2xl:text-2xl">{sub.title}</h3>
									{sub.subtitle && (
										<p class="mt-1 text-sm text-foreground/60 2xl:text-base">{sub.subtitle}</p>
									)}
									{sub.note && (
										<p class="mt-2 max-w-2xl text-xs leading-relaxed text-foreground/50 2xl:text-sm">{sub.note}</p>
									)}
								</div>
							)}

							<!-- Photo grid -->
							<div class="columns-2 gap-3 sm:columns-3 md:columns-4 2xl:columns-5 2xl:gap-4">
								{sub.images.map((id) => (
									<a
										href={`/gallery/${id}.jpg`}
										data-lightbox={`section-${si}-sub-${section.subsections.indexOf(sub)}`}
										class="group mb-3 block overflow-hidden rounded-xl 2xl:mb-4 2xl:rounded-2xl"
									>
										<img
											src={`/gallery/${id}.jpg`}
											alt=""
											loading="lazy"
											decoding="async"
											class="w-full transition-transform duration-500 group-hover:scale-105"
										/>
									</a>
								))}
							</div>
						</div>
					))}
				</section>
			))}
		</main>

		<!-- Footer -->
		<footer class="border-t border-border/30 bg-surface/40 py-10">
			<div class="mx-auto flex w-full max-w-7xl flex-col items-center gap-4 px-6 text-center 2xl:px-8">
				<a href="/" class="flex items-center gap-3">
					<img src="/icon.jpg" alt="HRBC" class="h-10 w-auto rounded-lg" />
					<span class="font-bold uppercase tracking-widest">Fundación HRBC</span>
				</a>
				<p class="max-w-md text-sm text-foreground/50">
					Galería fotográfica · Registro de programas e iniciativas 2008–2015
				</p>
			</div>
		</footer>

		<script>
			import lightbox from "lightbox2";
			lightbox.option({
				wrapAround: true,
				disableScrolling: true,
				resizeDuration: 200,
				fadeDuration: 300,
				imageFadeDuration: 300,
				albumLabel: "Foto %1 de %2",
			});
		</script>
	</body>
</html>
