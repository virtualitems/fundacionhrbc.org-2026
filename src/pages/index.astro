---
import "../styles/global.css";
import Icon from "../components/Icon.astro";
import UsersIcon from "heroicons/24/outline/users.svg?raw";
import MapPinIcon from "heroicons/24/outline/map-pin.svg?raw";
import CheckCircleIcon from "heroicons/24/outline/check-circle.svg?raw";
import ArrowRightIcon from "heroicons/24/outline/arrow-right.svg?raw";

const impactAreas = [
	{
		title: "Atención a poblaciones vulnerables",
		description:
			"Ofrecemos apoyo especializado a comunidades en situaciones difíciles, mitigando barreras y acercando recursos para su recuperación y empoderamiento.",
	},
	{
		title: "Habilitación y rehabilitación integral",
		description:
			"Brindamos procesos de inclusión, habilitación y rehabilitación basados en comunidad para fortalecer autonomía, participación y calidad de vida.",
	},
	{
		title: "Orientación y participación social",
		description:
			"Acompañamos proyectos de vida, formación para el trabajo y espacios de liderazgo, resiliencia y vinculación activa con la comunidad.",
	},
];

const programs = [
	{
		name: "Programa de Aprendizaje Vital",
		status: "En desarrollo",
		description:
			"Fortalecemos habilidades de autogestión, conciencia social, resiliencia y liderazgo para que cada persona dirija su vida con autonomía y propósito.",
	},
	{
		name: "Sembrando Arte, Cosechando Esperanzas",
		status: "En desarrollo",
		description:
			"Talleres de ocupación del tiempo libre y expresión creativa para jóvenes, enfocados en inclusión, pertenencia y desarrollo comunitario.",
	},
	{
		name: "Habilitación y Rehabilitación Basada en Comunidad",
		status: "Activo",
		description:
			"Asesoramos a personas, familias e instituciones en educación inclusiva, accesibilidad, diseño universal y participación con enfoque de derechos.",
	},
];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/jpeg" href="/favicon.jpg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="canonical" content="fundacionhrbc.org" />
		<meta name="author" content="Fundación HRBC" />
		<meta name="Keywords" content="inclusión, rehabilitación basada en comunidad, desarrollo personal, programas sociales, orientación, accesibilidad, educación inclusiva, empoderamiento, participación social" />
		<meta name="description" content="Fundación HRBC impulsa procesos de inclusión, rehabilitación basada en comunidad y desarrollo personal mediante programas con enfoque humano." />
		<title>Fundación HRBC</title>
	</head>
	<body class="bg-background text-foreground antialiased">
		<!-- Header -->
		<header class="fixed left-0 right-0 top-0 z-50 backdrop-blur-xl">
			<nav class="mx-auto flex w-full max-w-7xl items-center justify-between border-b border-border/20 bg-background/80 px-6 py-4 2xl:px-8">
				<a href="#inicio" class="group flex items-center gap-3">
					<div class="inline-block overflow-hidden rounded-xl bg-white p-1.5 shadow-md transition-transform duration-300 group-hover:scale-105">
						<img src="/icon.jpg" alt="HRBC Logo" class="block h-10 w-auto" />
					</div>
					<span class="font-bold uppercase tracking-[0.15em]">Fundación HRBC</span>
				</a>
				<div class="hidden items-center gap-2 2xl:flex">
					<a class="px-4 py-2 text-sm font-medium transition hover:text-secondary" href="#nosotros">Nosotros</a>
					<a class="px-4 py-2 text-sm font-medium transition hover:text-secondary" href="#impacto">Impacto</a>
					<a class="px-4 py-2 text-sm font-medium transition hover:text-secondary" href="#programas">Programas</a>
					<a class="px-4 py-2 text-sm font-medium transition hover:text-secondary" href="/gallery">Galería</a>
					<a class="ml-3 rounded-xl bg-secondary px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-accent" href="#contacto">Contactar</a>
				</div>
			</nav>
		</header>

		<!-- Hero -->
		<section id="inicio" class="relative overflow-hidden pt-20">
			<!-- Background gradient -->
			<div class="pointer-events-none absolute inset-0 -z-10 bg-linear-to-br from-secondary/10 via-background to-accent/5"></div>
			<div class="pointer-events-none absolute right-0 top-40 -z-10 size-80 rounded-full bg-linear-to-br from-accent/20 to-transparent blur-[100px] 2xl:size-150"></div>

			<div class="mx-auto grid w-full max-w-7xl items-center gap-8 px-6 py-12 2xl:min-h-screen 2xl:grid-cols-[1.2fr_0.8fr] 2xl:gap-16 2xl:px-8 2xl:py-20">
				<div class="flex flex-col gap-6 2xl:gap-10">

					<div class="space-y-6">
						<h1 class="font-['Space_Grotesk',sans-serif] text-4xl font-black leading-[1.05] tracking-tight 2xl:text-8xl">
							Potenciamos capacidades para una <span class="text-secondary">vida con autonomía</span>
						</h1>
						<p class="max-w-2xl text-base leading-relaxed text-foreground/70 2xl:text-2xl">
							Impulsamos el desarrollo personal y comunitario con programas de inclusión, orientación y rehabilitación basada en comunidad.
						</p>
					</div>

					<div class="flex flex-col gap-4 2xl:flex-row 2xl:flex-wrap">
						<a href="#programas" class="group inline-flex items-center justify-center gap-2 rounded-full bg-secondary px-8 py-4 font-bold text-white shadow-xl transition hover:scale-105 hover:shadow-2xl 2xl:justify-start">
							Ver programas
						<Icon icon={ArrowRightIcon} class="size-5 transition-transform group-hover:translate-x-1" />
						</a>
						<a href="/gallery" class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-accent/50 px-8 py-4 font-bold text-accent transition hover:border-accent hover:bg-accent/10 2xl:justify-start">
							Ver impacto
						</a>
						<a href="#contacto" class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-foreground/10 px-8 py-4 font-bold transition hover:border-secondary hover:bg-secondary/5 hover:text-secondary 2xl:justify-start">
							Colaborar
						</a>
					</div>

					<!-- Stats -->
					<div class="grid grid-cols-3 gap-4 border-t border-border/30 pt-6 2xl:gap-6 2xl:pt-10">
						<div>
							<div class="text-3xl font-black text-secondary 2xl:text-5xl">18</div>
							<div class="mt-1 text-xs font-medium text-foreground/60 2xl:mt-2 2xl:text-sm">Años de servicio</div>
						</div>
						<div>
							<div class="text-3xl font-black text-accent 2xl:text-5xl">1000+</div>
							<div class="mt-1 text-xs font-medium text-foreground/60 2xl:mt-2 2xl:text-sm">Personas beneficiadas</div>
						</div>
						<div>
							<div class="text-3xl font-black text-secondary 2xl:text-5xl">46%</div>
							<div class="mt-1 text-xs font-medium text-foreground/60 2xl:mt-2 2xl:text-sm">Jóvenes buscan orientación</div>
						</div>
					</div>
				</div>

				<!-- Hero visual card -->
			<div class="relative 2xl:min-h-150">
					<div class="absolute inset-0 rounded-[3rem] bg-linear-to-br from-secondary/20 to-accent/20 blur-2xl"></div>
					<div class="relative flex h-full flex-col gap-4 overflow-hidden rounded-4xl border border-border/40 bg-linear-to-br from-background to-surface/50 p-6 shadow-2xl backdrop-blur 2xl:rounded-[3rem] 2xl:p-8">
						<div class="flex-1 rounded-2xl bg-linear-to-br from-foreground to-secondary p-6 text-white 2xl:p-8">
							<div class="mb-3 text-xs font-bold uppercase tracking-widest text-accent">Nuestra visión</div>
							<p class="text-xl font-bold leading-tight 2xl:text-3xl">
								Una sociedad inclusiva, accesible y capaz de desarrollar al máximo su potencial humano
							</p>
						</div>

						<div class="grid grid-cols-2 gap-4">
							<div class="rounded-2xl border border-border/40 bg-background/80 p-6">
								<div class="mb-3 flex size-10 items-center justify-center rounded-xl bg-secondary/20 text-secondary">
									<Icon icon={UsersIcon} class="size-6" />
								</div>
								<div class="font-bold">Inclusión</div>
								<div class="mt-1 text-sm text-foreground/60">Procesos centrados en la persona</div>
							</div>
							<div class="rounded-2xl bg-secondary/10 p-6">
								<div class="mb-3 flex size-10 items-center justify-center rounded-xl bg-secondary/30 text-secondary">
									<Icon icon={MapPinIcon} class="size-6" />
								</div>
								<div class="font-bold">Comunidad</div>
								<div class="mt-1 text-sm text-foreground/60">Trabajo territorial y redes locales</div>
							</div>
							<div class="col-span-2 rounded-2xl bg-accent/10 p-6">
								<div class="mb-3 flex size-10 items-center justify-center rounded-xl bg-accent/30 text-accent">
									<Icon icon={CheckCircleIcon} class="size-6" />
								</div>
								<div class="font-bold">Desarrollo integral</div>
								<div class="mt-1 text-sm text-foreground/60">Educación, accesibilidad y proyecto de vida</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Quienes somos -->
		<section id="nosotros" class="relative overflow-hidden py-16 2xl:py-28">
			<div class="mx-auto w-full max-w-7xl px-6 2xl:px-8">
				<div class="grid items-start gap-10 2xl:items-center 2xl:grid-cols-[0.5fr_1fr] 2xl:gap-16">
					<div class="space-y-6">
						<div class="inline-block rounded-full border border-secondary/30 bg-secondary/5 px-4 py-2 text-sm font-semibold text-secondary">
							— Sobre nosotros
						</div>
						<h2 class="font-['Space_Grotesk',sans-serif] text-3xl font-black leading-tight tracking-tight 2xl:text-6xl">
							Rehabilitación basada en comunidad con enfoque <span class="text-secondary">humano</span>
						</h2>
					</div>

					<div class="space-y-6">
						<p class="text-base leading-relaxed text-foreground/80 2xl:text-xl">
								Fundación HRBC brinda asesoría en educación inclusiva, habilitación social, accesibilidad y diseño universal. Nuestro trabajo conecta <strong class="font-bold text-secondary">derechos humanos</strong>, <strong class="font-bold text-accent">actitud de servicio</strong> y acompañamiento cercano.
						</p>
						<div class="border-l-4 border-accent pl-6">
							<p class="text-base leading-relaxed text-foreground/80 2xl:text-xl">
									Diseñamos procesos personalizados, presenciales y virtuales, para que cada persona o institución alcance <strong class="font-bold text-secondary">su máximo potencial con autonomía</strong>.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Que hacemos -->
		<section id="impacto" class="relative overflow-hidden bg-surface/30 py-16 2xl:py-28">
			<div class="pointer-events-none absolute right-0 top-0 -z-10 size-125 rounded-full bg-linear-to-br from-accent/10 to-transparent blur-[80px]"></div>

			<div class="mx-auto w-full max-w-7xl px-6 2xl:px-8">
				<div class="mb-10 max-w-3xl space-y-4 2xl:mb-16 2xl:space-y-6">
					<div class="inline-block rounded-full border border-accent/30 bg-accent/5 px-4 py-2 text-sm font-semibold text-accent">
						— Nuestro impacto
					</div>
					<h2 class="font-['Space_Grotesk',sans-serif] text-3xl font-black leading-tight tracking-tight 2xl:text-7xl">
						De barreras a <span class="bg-linear-to-r from-secondary to-accent bg-clip-text text-transparent">oportunidades</span>
					</h2>
					<p class="text-base leading-relaxed text-foreground/70 2xl:text-xl">
						Estas son las líneas de trabajo que orientan nuestros programas, alianzas e intervenciones.
					</p>
				</div>

				<div class="grid gap-6 2xl:grid-cols-3 2xl:gap-8">
					{impactAreas.map((area, idx) => (
						<article class="group rounded-3xl border border-border/40 bg-background p-8 shadow-lg transition hover:-translate-y-2 hover:border-secondary/50 hover:shadow-2xl">
							<div class="mb-6 flex size-14 items-center justify-center rounded-2xl bg-linear-to-br from-secondary to-accent text-2xl font-black text-white">
								{idx + 1}
							</div>
							<h3 class="mb-4 text-2xl font-bold">{area.title}</h3>
							<p class="leading-relaxed text-foreground/70">{area.description}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<!-- Programas -->
		<section id="programas" class="relative overflow-hidden py-16 2xl:py-28">
			<div class="pointer-events-none absolute left-0 top-0 -z-10 size-150 rounded-full bg-linear-to-br from-secondary/10 to-transparent blur-[100px]"></div>

			<div class="mx-auto w-full max-w-7xl px-6 2xl:px-8">
				<div class="mb-10 space-y-4 text-center 2xl:mb-16 2xl:space-y-6">
					<div class="inline-block rounded-full border border-secondary/30 bg-secondary/5 px-4 py-2 text-sm font-semibold text-secondary">
						— Programas activos
					</div>
					<h2 class="font-['Space_Grotesk',sans-serif] text-3xl font-black leading-tight tracking-tight 2xl:text-7xl">
						Programas para <span class="text-secondary">elevar el potencial</span>
					</h2>
					<p class="mx-auto max-w-3xl text-base leading-relaxed text-foreground/70 2xl:text-xl">
						Cada iniciativa responde a necesidades reales de inclusión, orientación, rehabilitación y participación social.
					</p>
				</div>

				<div class="grid gap-6 2xl:grid-cols-3 2xl:gap-8">
					{programs.map((program) => (
						<article class="group rounded-3xl border border-border/40 bg-linear-to-br from-background to-surface/50 p-8 shadow-lg transition hover:-translate-y-2 hover:shadow-2xl">
							<span class="mb-6 inline-block rounded-full bg-linear-to-r from-accent to-secondary px-4 py-1.5 text-xs font-black uppercase tracking-widest text-white">
								{program.status}
							</span>
							<h3 class="mb-4 text-2xl font-bold leading-tight">{program.name}</h3>
							<p class="leading-relaxed text-foreground/70">{program.description}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<!-- Contacto -->
		<section id="contacto" class="relative overflow-hidden bg-surface/30 py-16 2xl:py-28">
			<div class="pointer-events-none absolute right-0 top-0 -z-10 size-125 rounded-full bg-linear-to-br from-accent/10 to-transparent blur-[80px]"></div>

			<div class="mx-auto w-full max-w-6xl px-6 2xl:px-8">
				<div class="grid gap-8 2xl:grid-cols-2 2xl:items-center">
					<div class="space-y-8">
						<div>
							<div class="mb-6 inline-block rounded-full border border-secondary/30 bg-secondary/5 px-4 py-2 text-sm font-semibold text-secondary">
								— Contacto
							</div>
							<h2 class="mb-4 font-['Space_Grotesk',sans-serif] text-3xl font-black leading-tight tracking-tight 2xl:mb-6 2xl:text-5xl">
								Conversemos sobre <span class="text-secondary">participación y alianzas</span>
							</h2>
						</div>
						<div class="space-y-4 text-foreground/70">
							<p class="text-base leading-relaxed">
								Si necesitas información sobre programas, participación o servicios de asesoría, escríbenos y coordinamos la mejor ruta de atención.
							</p>
						</div>
					</div>

					<div class="rounded-3xl bg-linear-to-br from-foreground to-secondary p-8 text-white shadow-2xl 2xl:min-h-105 2xl:self-stretch 2xl:p-10">
						<div class="flex h-full flex-col justify-between gap-10">
							<div>
								<div class="mb-4 text-xs font-bold uppercase tracking-widest text-accent">Contacto directo</div>
								<h3 class="max-w-sm text-xl font-bold leading-tight 2xl:text-3xl">
									Escríbenos para conocer programas, servicios y formas de participar.
								</h3>
							</div>
							<div class="space-y-4">
								<p class="text-lg font-semibold 2xl:text-2xl">fundacionhrbc@gmail.com</p>
								<p class="max-w-md text-base leading-relaxed text-white/80">
									Canal disponible para familias, aliados institucionales, consultas sobre accesibilidad y procesos de rehabilitación basada en comunidad.
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Footer -->
		<footer class="border-t border-white/10 bg-[#0b2545] py-12 text-background">
			<div class="mx-auto w-full max-w-7xl px-6 2xl:px-8">
				<div class="flex flex-col items-start justify-between gap-6 text-left text-sm 2xl:flex-row 2xl:items-start">
					<div class="space-y-2 text-background/75">
						<p>© 2026 Fundación HRBC. Inclusión, rehabilitación y desarrollo comunitario.</p>
						<p>Trabajamos para que cada persona desarrolle su máximo potencial en comunidad.</p>
						<div class="mt-4 inline-block overflow-hidden rounded-2xl bg-white p-3 shadow-md">
							<img src="/icon.jpg" alt="Logo Fundación HRBC" class="block h-16 w-auto" />
						</div>
					</div>
					<div class="flex flex-col items-start gap-3 2xl:items-end">
						<p class="text-xs font-bold uppercase tracking-widest text-background/60">Documentos</p>
						<a href="/existencia-900126947-6.pdf" target="_blank" rel="noreferrer" class="font-semibold text-accent transition hover:text-white hover:underline">
							Certificado de existencia
						</a>
						<a href="/lineamientos-nacionales-rbc.pdf" target="_blank" rel="noreferrer" class="font-semibold text-accent transition hover:text-white hover:underline">
							Lineamientos nacionales de RBC
						</a>
						<a href="/reconocimiento-ministerio-salud.pdf" target="_blank" rel="noreferrer" class="font-semibold text-accent transition hover:text-white hover:underline">
							Reconocimiento del Ministerio de Salud y Protección Social de Colombia
						</a>
						<a href="https://bibliotecadigital.univalle.edu.co/entities/publication/2e472ae5-e36a-4f23-9d02-de49e31f9dca" target="_blank" rel="noreferrer" class="font-semibold text-accent transition hover:text-white hover:underline">
							Reconocimiento de la Universidad del Valle de Colombia
						</a>
					</div>
				</div>
			</div>
		</footer>
	</body>
</html>
